{
  "name": "C-Sight Salesforce Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  },
  "postCreateCommand": "npm install -g @salesforce/cli@latest && echo y | sf plugins install sfdx-git-delta && npm ci",
  "customizations": {
    "vscode": {
      "extensions": [
        "salesforce.salesforcedx-vscode",
        "salesforce.salesforcedx-vscode-apex",
        "salesforce.salesforcedx-vscode-lwc",
        "salesforce.salesforcedx-vscode-core",
        "github.vscode-github-actions"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "salesforcedx-vscode-apex.java.home": "/usr/local/sdkman/candidates/java/current"
      }
    }
  },
  "forwardPorts": [],
  "remoteUser": "vscode"
}
